{
   "name": "dive-pos-frontend",
   "version": "0.1.0",
   "private": true,
   "scripts": {
      "dev:all": "turbo run dev --continue",
      "dive:all": "concurrently -n frontend,backend -c cyan,blue \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
      "dev": "next dev --port 7777",
      "dev:frontend": "pnpm run dev",
      "dev:backend": "cd backend && cross-env PORT=7771 MCP_MEMORY_PORT=7772 DB_PORT=5433 pnpm dev",
      "dev:memory-mcp": "cd backend && cross-env MCP_MEMORY_PORT=7772 pnpm run start:mcp:dev",
      "dev:mcp": "cd backend && pnpm run start:mcp:dev",
      "dev:diveseeks-mcp": "cd diveseeks-mcp && pnpm run dev",
      "dev:diveseeks-mcp:http": "cd diveseeks-mcp && pnpm run dev:http",
      "dev:extension": "cd diveseeks-extension && pnpm run watch",
      "dev:open-design": "docker compose up open-design",
      "build:open-design": "docker compose build open-design",
      "build": "turbo run build",
      "build:diveseeks-mcp": "cd diveseeks-mcp && pnpm run build",
      "build:extension": "cd diveseeks-extension && pnpm run build",
      "build:extension:package": "cd diveseeks-extension && pnpm run package",
      "start": "turbo run start",
      "start:frontend": "next start --port 7777",
      "start:backend": "cd backend && cross-env PORT=7771 MCP_MEMORY_PORT=7772 pnpm run start:prod",
      "start:diveseeks-mcp": "cd diveseeks-mcp && pnpm run start",
      "start:diveseeks-mcp:http": "cd diveseeks-mcp && pnpm run start:http",
      "test": "turbo run test",
      "test:coverage": "turbo run test -- --coverage",
      "test:frontend": "jest",
      "test:backend": "cd backend && pnpm run test",
      "test:backend:watch": "cd backend && pnpm run test:watch",
      "test:backend:cov": "cd backend && pnpm run test:cov",
      "test:backend:e2e": "cd backend && pnpm run test:e2e",
      "test:diveseeks-mcp": "cd diveseeks-mcp && pnpm run test",
      "check-types": "turbo run check-types",
      "lint": "turbo run lint",
      "lint:backend": "cd backend && pnpm run lint",
      "format": "prettier --write .",
      "format:backend": "cd backend && pnpm run format"
   },
   "dependencies": {
      "@ai-sdk/deepseek": "^2.0.32",
      "@ai-sdk/google": "^3.0.62",
      "@ai-sdk/mcp": "^1.0.35",
      "@ai-sdk/openai": "^3.0.52",
      "@ai-sdk/react": "^3.0.144",
      "@base-ui/react": "^1.2.0",
      "@dive-pos/types": "workspace:*",
      "@dnd-kit/core": "^6.3.1",
      "@dnd-kit/modifiers": "^9.0.0",
      "@dnd-kit/sortable": "^10.0.0",
      "@dnd-kit/utilities": "^3.2.2",
      "@hookform/resolvers": "^5.2.2",
      "@modelcontextprotocol/sdk": "^1.29.0",
      "@openrouter/ai-sdk-provider": "^2.6.0",
      "@puckeditor/core": "^0.21.2",
      "@radix-ui/react-slot": "^1.2.4",
      "@tailwindcss/typography": "^0.5.19",
      "@tanstack/react-query": "^5.90.21",
      "@tanstack/react-table": "^8.21.3",
      "@xyflow/react": "^12.10.2",
      "ai": "^6.0.154",
      "axios": "^1.13.6",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "cmdk": "^1.1.1",
      "cookies-next": "^6.1.1",
      "date-fns": "^4.1.0",
      "embla-carousel-react": "^8.6.0",
      "framer-motion": "^12.38.0",
      "input-otp": "^1.4.2",
      "lucide-react": "^0.577.0",
      "next": "^16.2.2",
      "next-themes": "^0.4.6",
      "react": "19.2.4",
      "react-day-picker": "^9.14.0",
      "react-dom": "19.2.4",
      "react-hook-form": "^7.71.2",
      "react-icons": "^5.6.0",
      "react-markdown": "^10.1.0",
      "react-resizable-panels": "^4.7.2",
      "recharts": "^2.15.4",
      "remark-gfm": "^4.0.1",
      "socket.io-client": "^4.8.3",
      "sonner": "^2.0.7",
      "tailwind-merge": "^3.5.0",
      "tw-animate-css": "^1.4.0",
      "vaul": "^1.1.2",
      "zod": "^4.4.2",
      "zustand": "^5.0.11"
   },
   "devDependencies": {
      "@tailwindcss/postcss": "^4.0.0",
      "@tanstack/intent": "^0.0.23",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2",
      "@types/jest": "^30.0.0",
      "@types/node": "^22.10.7",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "concurrently": "^9.2.1",
      "cross-env": "^10.1.0",
      "eslint": "^9.18.0",
      "eslint-config-next": "16.2.2",
      "jest": "^30.0.0",
      "jest-environment-jsdom": "^30.2.0",
      "prettier": "^3.4.2",
      "shadcn": "^4.1.1",
      "tailwindcss": "^4.0.0",
      "ts-jest": "^29.2.5",
      "turbo": "^2.9.14",
      "typescript": "^5.7.3"
   },
   "packageManager": "pnpm@10.28.2",
   "keywords": [
      "tanstack-intent"
   ],
   "files": [
      "skills",
      "!skills/_artifacts"
   ]
}
