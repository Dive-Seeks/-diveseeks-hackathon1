{
  "name": "dive-pos-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest build && concurrently -k -n build,api,mcp -c gray,blue,magenta \"nest build --watch --preserveWatchOutput\" \"nodemon --config nodemon.json\" \"nodemon --config nodemon-mcp.json\"",
    "dev:api-only": "pnpm run start:dev",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:mcp": "nest start --entryFile mcp-main",
    "start:mcp:dev": "nest start --watch --entryFile mcp-main",
    "debug:postcode": "ts-node ./scripts/debug-postcode-autocomplete.ts",
    "start:dev": "nest start --watch",
    "start:dev:win": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "check-types": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix && npm run check:boundaries && npm run check:no-anthropic",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "check:no-anthropic": "ts-node ./scripts/check-no-anthropic.ts",
    "check:boundaries": "depcruise --config .dependency-cruiser.cjs src",
    "audit:tenant": "ts-node ./scripts/audit-tenant-isolation.ts",
    "audit:ai-providers": "bash scripts/audit-ai-providers.sh",
    "audit:fire-forget": "bash scripts/audit-fire-forget.sh",
    "audit:all": "npm run audit:tenant && npm run audit:ai-providers && npm run audit:fire-forget",
    "start:ai-worker:prod": "AI_WORKER_MODE=worker node dist/main",
    "madge:circular": "madge --circular --extensions ts src/",
    "madge:image": "madge --image madge-graph.svg --extensions ts src/"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.32",
