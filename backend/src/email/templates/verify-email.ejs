<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Verify your email</title>
  <style>
    @import url('https://fonts.cdnfonts.com/css/hk-grotesk');
    @import url('https://fonts.cdnfonts.com/css/clash-display');
    
    body {
      font-family: 'HK Grotesk', ui-sans-serif, system-ui, sans-serif;
      background-color: #fcfcfc;
      color: #000000;
      margin: 0;
      padding: 40px 20px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    .container {
      max-width: 500px;
      margin: 0 auto;
      background-color: #ffffff;
      border: 1px solid #e5e5e5;
      border-radius: 10px;
      padding: 40px;
      text-align: center;
    }
    .logo {
      font-family: 'Clash Display', sans-serif;
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 30px;
      letter-spacing: -0.02em;
    }
    h1 {
      font-family: 'Clash Display', sans-serif;
      font-size: 28px;
      font-weight: 500;
      margin-bottom: 20px;
      letter-spacing: -0.02em;
    }
    p {
      font-size: 16px;
      color: #4a4a4a;
      margin-bottom: 30px;
    }
    .button {
      display: inline-block;
      background-color: #000000;
      color: #ffffff !important;
      text-decoration: none;
      padding: 12px 24px;
      border-radius: 10px;
      font-weight: 500;
      font-size: 16px;
      margin-bottom: 30px;
    }
    .footer {
      font-size: 14px;
      color: #888888;
      margin-top: 40px;
      border-top: 1px solid #e5e5e5;
      padding-top: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="logo">Dive POS</div>
    <h1>Verify your email</h1>
    <p>Welcome to Dive POS! To get started, please verify your email address by clicking the button below.</p>
    <a href="<%= url %>" class="button">Verify Email</a>
    <p style="font-size: 14px; color: #888888; margin-bottom: 0;">If you didn't request this, you can safely ignore this email.<br>This link will expire in 24 hours.</p>
    <div class="footer">
      &copy; 2026 Dive POS. All rights reserved.
    </div>
  </div>
</body>
</html>