# Application configuration
PORT=7771
NODE_ENV=development

# Database configuration (example)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dive_pos

# JWT configuration (example)
JWT_SECRET=yoursecretkey
JWT_EXPIRES_IN=1d

# LLM provider keys — the brain runs DeepSeek primary, Google Gemini fallback.
# At least one of DEEPSEEK_API_KEY / GOOGLE_AI_API_KEY must be set or the AI framework fails at runtime.
DEEPSEEK_API_KEY=sk-...
GOOGLE_AI_API_KEY=                   # Gemini fallback + image analysis + menu generation
GOOGLE_GENERATIVE_AI_API_KEY=        # Alias of GOOGLE_AI_API_KEY — either name works
GOOGLE_API_KEY=                      # Tier-2 intent classification (brain ideation gate)
OPENAI_API_KEY=                      # DALL-E image generation + menu cascade fallback
OPENROUTER_API_KEY=                  # OpenRouter model access (brain session + menu cascade)
BRAIN_SHARED_SECRET=dev-secret-change-me  # MCP registry token signing — MUST change in prod

# GitHub OAuth Integration (DiveSeeks GitHub Eye)
GITHUB_CLIENT_ID=                    # GitHub OAuth App client ID
GITHUB_CLIENT_SECRET=                # GitHub OAuth App client secret
GITHUB_OAUTH_CALLBACK_URL=https://yourdomain.com/api/coding/github/oauth/callback
GITHUB_REPOS_BASE_PATH=/tmp/abigail-repos  # Local clone storage on VPS

# Sandbox mode: mock | docker | (unset = auto-detect by OS)
SANDBOX_MODE=mock

# AI worker scaling mode:
#   worker   — this process runs ONLY BullMQ AI processors (no HTTP server)
#   disabled — this process runs HTTP only; AI processors do NOT consume jobs
#   <unset>  — single-node dev default: both HTTP and processors run
AI_WORKER_MODE=

# Redis (required for BullMQ queues and distributed cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Hermes User Behavior Agent
HERMES_TOPIC_REPEAT_THRESHOLD=3
HERMES_RAPID_SEND_WINDOW_SEC=90
HERMES_TAB_SWITCH_THRESHOLD=5
HERMES_SIMILARITY_THRESHOLD=0.85
HERMES_LLM_CLASSIFY_MODEL=gemini-2.0-flash-lite

# MCP servers (give specialist agents read access to data + search)
# Without these, agents run with empty Postgres/Search toolbelts (warned at startup).
# Each must point at an MCP server running in streamable-http mode.
MCP_POSTGRES_URL=                    # e.g. http://localhost:5433/mcp — Postgres MCP server (DB introspection)
MCP_SEARCH_URL=                      # e.g. http://localhost:5434/mcp — Search MCP server (web/code search)

# DiveSeeks Memory MCP server — start it with `pnpm run dev:memory-mcp` from repo root.
# scan_memory_index / fetch_tenant_episodes tools are unavailable to agents unless this is running.
MCP_MEMORY_PORT=7772                 # Port the Memory MCP streamable-http transport listens on
MCP_NEST_PORT=7773                   # Port for the NestJS DI wrapper that hosts the Memory MCP

# Web Research / Browser Pipeline
PLAYWRIGHT_MCP_URL=http://localhost:3100 # Playwright SSE MCP server endpoint
FIRECRAWL_API_KEY=                   # Firecrawl API key (Tier-3 FirecrawlProvider scraper)


# Phase 2 Part B — ADK convergence
WORKFLOW_BACKEND=bullmq                 # bullmq | adk  (global; default bullmq)
ADK_REASONING_ENGINE=                   # projects/.../reasoningEngines/ID
ADK_EVENTS_SUBSCRIPTION=                # projects/.../subscriptions/adk-phase-events-sub

# --- Hermes-agent under Abigail (Phase 1) ---
SPECIALIST_BACKEND=local
HERMES_AGENT_ENABLED_TENANTS=
HERMES_AGENT_FALLBACK_LOCAL=true
HERMES_AGENT_TIMEOUT_MS=300000
HERMES_AGENT_IDLE_MINUTES=30
HERMES_AGENT_API_PORT=8642
SUPERVISOR_URL=http://container-supervisor:18800   # dev (backend on host): http://localhost:18800
SUPERVISOR_API_KEY=                  # REQUIRED — supervisor refuses all requests when unset
HERMES_AGENT_IMAGE=nousresearch/hermes-agent:v2026.6.5
DOCKER_GID=999                       # gid of /var/run/docker.sock: stat -c '%g' /var/run/docker.sock
OD_API_TOKEN=                        # open-design bridge token (no hardcoded fallback)
