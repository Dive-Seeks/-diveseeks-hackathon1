# Transport mode: stdio (local/Claude Code) | http (Cloud Run)
TRANSPORT=http

# Port Cloud Run listens on (Cloud Run injects this automatically)
PORT=8080

# Your VPS backend API URL — replace with your VPS public IP or domain
DIVE_API_URL=https://dashboard.divepos.com/api

# Service API key — generate with: openssl rand -hex 32
# Must match MCP_SERVICE_KEY in backend/.env.production
DIVE_MCP_API_KEY=your-service-api-key-here

# Node environment
NODE_ENV=production
